/*Problem Description:

TCS wants to analyze salary distribution across departments. For each department, calculate:

Total number of employees
Average salary
Minimum salary
Maximum salary
Salary range (max - min)
Number of employees earning above department average
Only include departments with at least 5 employees. Output columns: department, employee_count, avg_salary, min_salary, max_salary, salary_range, above_avg_count. Sort by avg_salary DESC.*/

WITH department_salary AS (
    SELECT
        employee_id,
        department,
        salary,
        AVG(salary) OVER (PARTITION BY department) AS dept_avg
    FROM employees
)

SELECT
    department,
    COUNT(employee_id) AS employee_count,
    ROUND(AVG(salary), 2) AS avg_salary,
    MIN(salary) AS min_salary,
    MAX(salary) AS max_salary,
    MAX(salary) - MIN(salary) AS salary_range,
    SUM(CASE
            WHEN salary > dept_avg THEN 1
            ELSE 0
        END) AS above_avg_count
FROM department_salary
GROUP BY department
HAVING COUNT(employee_id) >= 5
ORDER BY avg_salary DESC;
